<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>Bonoos.iikoFront.LoyaltyPlugin</AssemblyName>
    <RootNamespace>Bonoos.iikoFront.LoyaltyPlugin</RootNamespace>
    <TargetFramework>net472</TargetFramework>
    <LangVersion>10.0</LangVersion>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Manifest.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <None Update="Bonoos.LoyaltyPlugin.config.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="Resto.Front.Api.V9" Version="9.5.6059" />
    <PackageReference Include="System.Net.Http" Version="4.3.4" PrivateAssets="all" />
  </ItemGroup>

</Project>
